{
  "expo": {
    "name": "Hope Bridge",
    "slug": "vpsd-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/hopebridge-icon.png",
    "scheme": "hopebridge",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rootcee.hopebridge",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.rootcee.hopebridge",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "appStore": {
        "privacyPolicyUrl": "https://example.com/privacy-policy",
        "supportUrl": "https://example.com/support",
        "supportEmail": "support@example.com"
      },
      "eas": {
        "projectId": "1adbe53a-21ec-43df-8426-2c0bb96c48ea"
      }
    },
    "owner": "rootcee",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1adbe53a-21ec-43df-8426-2c0bb96c48ea"
    }
  }
}
